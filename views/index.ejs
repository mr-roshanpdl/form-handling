<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Home Page</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css" />
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body>
  <div class="main min-h-screen w-full bg-zinc-900">
    <div class="form-container p-10 text-white">
      <form class="" action="/create" method="POST">
        <input name="title" class="outline-none px-5 py-2 block bg-zinc-800 w-full mt-2 rounded-lg" type="text"
          placeholder="Title goes here.." />

        <textarea name="task"
          class="outline-none px-5 py-2 block bg-zinc-800 w-full mt-2 resize-none min-h-[120px] rounded-lg"
          placeholder="write your task here.."></textarea>

        <button type="submit"
          class="mt-4 px-5 py-2 bg-blue-600 hover:bg-blue-700 rounded text-white font-medium transition-colors">
          Create Task
        </button>
      </form>
    </div>

    <div class="cards p-10 flex flex-wrap gap-3">
    <% if( varFiles.length > 0) { %>
    <% varFiles.forEach( function(file){ %>
        <div class="card min-w-72 border border-green-500 bg-zinc-800 px-3 py-4 rounded-lg sm:max-w-20 relative overflow-hidden">
        <h2 class="text-white truncate shrink-1 text-2xl tracking-tighter"> <%= file %> </h2>
        <div class="link flex justify-between items-center mt-5">
          <a class="text-blue-500 inline-block" href="/files/<%= file %>">Read more</a>
          <a class="text-zinc-500 inline-block" href="/edit/<%= file %>">Edit</a>
        </div>
        <a class="cross-mark-btn hover:bg-red-500 hover:text-white text-sm  absolute h-6 w-6 top-3 right-3 text-red-600 flex justify-center items-center" href="/delete/<%=file %>">
          <i class="fa-solid fa-xmark"></i>
        </a>
      </div>
    <% }) %>
      
    <% } else { %>  
      <h2 class="note-status text-zinc-400 px-3 tracking-tighter ">No task yet..</h2> 
    <% } %>  
    </div>
  </div>
</body>
</html>